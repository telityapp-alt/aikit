# ── Client (Vite, exposed to browser) ──────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# Jangan taruh secret server di `.env` karena file itu untuk client Vite.
# Semua secret di bawah ini masuk ke `.dev.vars` lokal dan ke Cloudflare secret env saat deploy.
# ── Server secrets → put in .dev.vars locally, Cloudflare dashboard in prod ──
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
# AUTOMATION_SUPABASE_URL=https://your-automation-project.supabase.co
# AUTOMATION_SUPABASE_SERVICE_ROLE_KEY=eyJ...   # isolated automation datastore
# ANTHROPIC_API_KEY=sk-ant-...
# BRIGHTDATA_API_KEY=...
# BRIGHTDATA_INSTAGRAM_PROFILES_DATASET_ID=gd_l1vikfch901nx3by4
# BRIGHTDATA_GOOGLE_MAPS_DATASET_ID=...
# BRIGHTDATA_TOKOPEDIA_DATASET_ID=...
# SCRAPECREATORS_API_KEY=...
# XENDIT_SECRET_KEY=xnd_...
# XENDIT_CALLBACK_TOKEN=...   # verifies incoming Xendit webhooks
