# ── Client (Vite, exposed to browser) ──────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# ── Server secrets → put in .dev.vars locally, Cloudflare dashboard in prod ──
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
# ANTHROPIC_API_KEY=sk-ant-...
# APIFY_API_TOKEN=apify_api_xxx
# APIFY_TIKTOK_ACTOR_ID=your-actor-id
# APIFY_TIKTOK_INPUT_TEMPLATE={"profiles":["{{handle}}"],"maxItems":"{{maxItems}}"}
# SCRAPECREATORS_API_KEY=...
# XENDIT_SECRET_KEY=xnd_...
# XENDIT_CALLBACK_TOKEN=...   # verifies incoming Xendit webhooks
