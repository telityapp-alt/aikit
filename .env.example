# ── Client (Vite, exposed to browser) ──────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# ── Server secrets → put in .dev.vars locally, Cloudflare dashboard in prod ──
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
# ANTHROPIC_API_KEY=sk-ant-...
# APIFY_API_TOKEN=apify_api_xxx
# APIFY_TIKTOK_ACTOR_ID=GdWCkxBtKWOsKjdch       # clockworks/tiktok-scraper
# APIFY_INSTAGRAM_ACTOR_ID=shu8hvrXbJbY3Eb9W   # apify/instagram-scraper
# APIFY_TIKTOK_ADS_ACTOR_ID=AovGexsTSmlalAFzp  # silva95gustavo/tiktok-ads-scraper
# APIFY_META_ADS_ACTOR_ID=XtaWFhbtfxyzqrFmd    # curious_coder/facebook-ads-library-scraper
# Optional override. If unset, the Worker builds the correct clockworks input automatically.
# APIFY_TIKTOK_INPUT_TEMPLATE={"profiles":["{{handle}}"],"resultsPerPage":"{{maxItems}}","profileScrapeSections":["videos"],"profileSorting":"latest"}
# SCRAPECREATORS_API_KEY=...
# XENDIT_SECRET_KEY=xnd_...
# XENDIT_CALLBACK_TOKEN=...   # verifies incoming Xendit webhooks
